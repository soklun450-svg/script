local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/tlredz/Library/refs/heads/main/redz-V5-remake/main.luau"))()

local Window = Library:MakeWindow({
  Title = "SK Hub",
  SubTitle = "STEVEKHMER",
  ScriptFolder = "redz-library-V5"
})

local Minimizer = Window:NewMinimizer({
  KeyCode = Enum.KeyCode.LeftControl
})

local MobileButton = Minimizer:CreateMobileMinimizer({
  Image = "rbxassetid://10734953451",
  BackgroundColor3 = Color3.fromRGB(0, 0, 0)
})

local Tab = Window:MakeTab({
  Title = "Main",
  Icon = "Home"
})

local Tab = Window:MakeTab({
  Title = "Settings",
  Icon = "settings"
})

Tab:AddToggle({
    Name = "Auto Fast Attack M1",
    Default = false,
    Callback = function(Value)
        getgenv().AutoFastM1 = Value
        
        if not Value then return end
        
        task.spawn(function()
            while getgenv().AutoFastM1 do
                pcall(function()
                    local player = game.Players.LocalPlayer
                    local character = player.Character
                    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
                    
                    local tool = character:FindFirstChildOfClass("Tool")
                    if not tool then return end
                    
                    -- Check weapon group (Melee, Sword, Blox Fruit, Gun) - works with tool name, ToolTip or WeaponType attribute
                    local weaponType = (tool:GetAttribute("WeaponType") or tool.ToolTip or tool.Name or ""):lower()
                    if not (weaponType:find("melee") or weaponType:find("sword") or weaponType:find("blox fruit") or weaponType:find("gun")) then
                        return
                    end
                    
                    local ReplicatedStorage = game:GetService("ReplicatedStorage")
                    local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
                    local RegisterAttack = Net:WaitForChild("RE/RegisterAttack")
                    local RegisterHit = Net:WaitForChild("RE/RegisterHit")
                    
                    -- Fire RegisterAttack for fast M1
                    RegisterAttack:FireServer(0)
                    
                    -- Auto attack ALL NPCs + Players in 250 studs range
                    for _, folder in ipairs({workspace:FindFirstChild("Enemies"), workspace:FindFirstChild("Characters")}) do
                        if folder then
                            for _, target in ipairs(folder:GetChildren()) do
                                if target \~= character 
                                    and target:FindFirstChild("HumanoidRootPart") 
                                    and target:FindFirstChild("Humanoid") 
                                    and target.Humanoid.Health > 0 then
                                    
                                    local distance = (target.HumanoidRootPart.Position - character.HumanoidRootPart.Position).Magnitude
                                    if distance <= 250 then
                                        -- Target hit part (standard for RegisterHit)
                                        local hitPart = target:FindFirstChild("Head") 
                                            or target:FindFirstChild("HumanoidRootPart") 
                                            or target:FindFirstChild("RightLowerLeg")
                                        
                                        if hitPart then
                                            local args = {
                                                hitPart,          -- Hit part
                                                {},               -- Parts table (standard)
                                                {},               -- Extra data
                                                "068b64cb"        -- Session ID (kept from your original)
                                            }
                                            RegisterHit:FireServer(unpack(args))
                                        end
                                    end
                                end
                            end
                        end
                    end
                end)
                
                task.wait(0.01) -- Super fast attack speed (M1 spam)
            end
        end)
    end
})

Window:Notify({
  Title = "New UI",
  Content = "this is new UI and Before it is broken",
  Image = "rbxassetid://10734953451",
  Duration = 5
})
