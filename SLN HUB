-- === CONFIG (slider completely removed - range is now fixed) ===
getgenv().AutoM1Enabled = false
getgenv().AutoM1Range = 250   -- Fixed at 250 studs (change this number if you want different range)

-- Auto attack loop (unchanged, works perfectly with fixed range)
task.spawn(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
    local RegisterAttack = Net:WaitForChild("RE/RegisterAttack")
    local RegisterHit = Net:WaitForChild("RE/RegisterHit")
    
    local weaponGroups = {"Melee", "Sword", "Blox Fruit", "Gun"}
    
    while task.wait(0.05) do -- Fast M1 spam
        if not getgenv().AutoM1Enabled then continue end
        
        pcall(function()
            local lp = game.Players.LocalPlayer
            local char = lp.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            
            local root = char.HumanoidRootPart
            local tool = char:FindFirstChildWhichIsA("Tool")
            
            -- Weapon group check
            local isValidWeapon = false
            if tool then
                local tip = tool.ToolTip or ""
                for _, group in ipairs(weaponGroups) do
                    if tip == group then
                        isValidWeapon = true
                        break
                    end
                end
            end
            if not isValidWeapon then return end
            
            -- Fire RegisterAttack first
            RegisterAttack:FireServer(1e-9)
            
            -- === PLAYERS ===
            for _, plr in ipairs(game.Players:GetPlayers()) do
                if plr == lp then continue end
                local pchar = plr.Character
                if not pchar or not pchar:FindFirstChild("Head") or not pchar:FindFirstChild("Humanoid") then continue end
                if pchar.Humanoid.Health <= 0 then continue end
                
                local dist = (root.Position - pchar.HumanoidRootPart.Position).Magnitude
                if dist <= getgenv().AutoM1Range then
                    local hitPart = pchar:FindFirstChild("Head") or pchar.HumanoidRootPart
                    
                    local args = {
                        hitPart,
                        {},
                        nil,
                        "068b64cb"
                    }
                    RegisterHit:FireServer(unpack(args))
                end
            end
            
            -- === NPCS ===
            local enemiesFolder = workspace:FindFirstChild("Enemies")
            if enemiesFolder then
                for _, npc in ipairs(enemiesFolder:GetChildren()) do
                    if not npc:FindFirstChild("Head") or not npc:FindFirstChild("Humanoid") then continue end
                    if npc.Humanoid.Health <= 0 then continue end
                    
                    local dist = (root.Position - npc.HumanoidRootPart.Position).Magnitude
                    if dist <= getgenv().AutoM1Range then
                        local hitPart = npc:FindFirstChild("Head") or npc.HumanoidRootPart
                        
                        local args = {
                            hitPart,
                            {},
                            nil,
                            "068b64cb"
                        }
                        RegisterHit:FireServer(unpack(args))
                    end
                end
            end
        end)
    end
end)

