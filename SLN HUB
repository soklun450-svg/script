-- Auto M1 High Range Logic (place this right after your RedzLib v5 setup / window creation)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local RegisterAttack = Net:WaitForChild("RE/RegisterAttack")
local RegisterHit = Net:WaitForChild("RE/RegisterHit")

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

getgenv().AutoM1HighRange = false

task.spawn(function()
  while task.wait(0.07) do  -- Fast spam rate (adjust if too aggressive)
    if not getgenv().AutoM1HighRange then continue end
    
    local character = LocalPlayer.Character
    if not (character and character:FindFirstChild("HumanoidRootPart")) then continue end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if not tool then continue end
    
    -- Only activate for melee, sword, blox fruit, gun (exact ToolTip match like official BF)
    local tip = tool.ToolTip
    if not (tip == "Melee" or tip == "Sword" or tip == "Blox Fruit" or tip == "Gun") then continue end
    
    local myRoot = character.HumanoidRootPart
    local myPos = myRoot.Position
    local range = 300  -- HIGH RANGE (any near me, 300 studs bypass)
    
    local hitTargets = {}
    
    -- NPC enemies
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if enemiesFolder then
      for _, enemy in ipairs(enemiesFolder:GetChildren()) do
        if enemy:IsA("Model") and enemy \~= character and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 and enemy:FindFirstChild("HumanoidRootPart") then
          local dist = (enemy.HumanoidRootPart.Position - myPos).Magnitude
          if dist <= range and dist > 4 then
            table.insert(hitTargets, enemy)
          end
        end
      end
    end
    
    -- Other players (Characters folder or direct)
    local charsFolder = workspace:FindFirstChild("Characters")
    if charsFolder then
      for _, char in ipairs(charsFolder:GetChildren()) do
        if char:IsA("Model") and char \~= character and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 and char:FindFirstChild("HumanoidRootPart") then
          local dist = (char.HumanoidRootPart.Position - myPos).Magnitude
          if dist <= range and dist > 4 then
            table.insert(hitTargets, char)
          end
        end
      end
    end
    
    if #hitTargets == 0 then continue end
    
    -- M1 Attack (RegisterAttack once per cycle)
    RegisterAttack:FireServer(0.5)
    
    -- Hit EVERY nearby target (any near me gets hit)
    for _, targetChar in ipairs(hitTargets) do
      local hitPart = targetChar:FindFirstChild("Head") or targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChildWhichIsA("BasePart")
      if hitPart then
        -- Your exact remote format, but with real hitPart instead of dummy MeshPart (works better for range)
        -- {} remains as in your example; [4] = your ID
        local args = {
          hitPart,
          {},
          [4] = "392ca9d8"
        }
        RegisterHit:FireServer(unpack(args))
      end
    end
  end
end)

