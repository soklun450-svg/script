-- Auto attack loop (put this once after all UI tabs are made)
task.spawn(function()
  local Players = game:GetService("Players")
  local Workspace = game:GetService("Workspace")
  local ReplicatedStorage = game:GetService("ReplicatedStorage")
  
  local LocalPlayer = Players.LocalPlayer
  local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
  local RegisterAttack = Net:WaitForChild("RE/RegisterAttack")
  local RegisterHit = Net:WaitForChild("RE/RegisterHit")
  
  while task.wait(0.08) do -- Fast M1 speed
    if not getgenv().AutoM1Enabled then continue end
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then continue end
    
    local root = character.HumanoidRootPart
    local tool = character:FindFirstChildOfClass("Tool")
    if not tool then continue end
    
    -- Group tool name check (Melee, Sword, Blox Fruit, Gun)
    local toolType = tool.ToolTip or tool.Name
    if not (toolType:find("Melee") or toolType:find("Sword") or toolType:find("Blox Fruit") or toolType:find("Gun")) then continue end
    
    -- Collect ALL NPCs + Players in 150 studs
    local targets = {}
    local baseHitPart = nil
    
    for _, folder in ipairs({Workspace.Enemies, Workspace.Characters}) do
      if folder then
        for _, target in ipairs(folder:GetChildren()) do
          if target \~= character and target:FindFirstChild("Humanoid") and target.Humanoid.Health > 0 and target:FindFirstChild("Head") and target:FindFirstChild("HumanoidRootPart") then
            local dist = (target.HumanoidRootPart.Position - root.Position).Magnitude
            if dist <= 150 then
              table.insert(targets, {target, target.Head})
              if not baseHitPart then baseHitPart = target.Head end
            end
          end
        end
      end
    end
    
    if baseHitPart and #targets > 0 then
      pcall(function()
        RegisterAttack:FireServer(0) -- Start attack packet
        task.wait() -- Tiny delay for validation
        
        local args = {
          baseHitPart,
          targets,
          {},
          "0684f062" -- YOUR NEW SESSION ID (hardcoded)
        }
        RegisterHit:FireServer(unpack(args))
      end)
    end
  end
end)

